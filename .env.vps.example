ENVIRONMENT=production
DATABASE_URL=postgresql+psycopg://spark:spark@postgres:5432/spark_iot
VALKEY_URL=redis://valkey:6379/0
JWT_SECRET=change-this-to-a-long-random-production-secret
CORS_ORIGINS=http://iot.rectronx.com,http://iot.rectronx.com:5173,https://iot.rectronx.com,https://iot.rectronx.com:5173
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CONSUMER_ENABLED=true
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@rectronx.com
APP_PUBLIC_URL=http://iot.rectronx.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=Spark IoT <no-reply@rectronx.com>
SMTP_USE_TLS=true
VITE_API_BASE=/api/v1
VITE_MQTT_HOST=iot.rectronx.com
VITE_MQTT_PORT=1883
VITE_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
VITE_MAP_ATTRIBUTION=OpenStreetMap contributors
